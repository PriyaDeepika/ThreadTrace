# Copy this file to .env and fill in your real values. Never commit .env itself.

# From Cognee Cloud console > API Keys page
COGNEE_SERVICE_URL=https://your-tenant.aws.cognee.ai
COGNEE_API_KEY=ck_your_api_key_here

# Cognee needs an LLM provider to build/query the graph.
# If you're using Cognee Cloud's managed LLM, you may not need this —
# check the Cognee Cloud console settings. If self-hosting, set your provider key:
# OPENAI_API_KEY=sk-...
